# Deal Radar OS — Environment Configuration
# Copy this file to .env and fill in real values

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./deal_radar.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/deal_radar

# ── App ───────────────────────────────────────────────────────────────────
DEBUG=true
APP_NAME=Deal Radar OS

# ── CoStar API (Production) ───────────────────────────────────────────────
# Obtain from: https://product.costar.com/api
COSTAR_API_KEY=
COSTAR_API_BASE=https://api.costar.com/v1

# ── Company Intelligence (Production) ────────────────────────────────────
# Apollo.io: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=
# ZoomInfo alternative:
ZOOMINFO_API_KEY=

# ── LinkedIn Sales Navigator (Optional) ───────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Virginia Public Records ────────────────────────────────────────────────
# Arlington County Open Data API (free)
ARLINGTON_PERMITS_API=https://data.arlingtonva.us/api/v2/catalog/datasets/building-permits
# Fairfax iCare API (free)
FAIRFAX_ICARE_API=https://icare.fairfaxcounty.gov/ffxcare/

# ── Notifications (Optional) ──────────────────────────────────────────────
# Slack webhook for daily briefing delivery
SLACK_WEBHOOK_URL=
